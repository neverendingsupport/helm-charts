{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "image": {
      "properties": {
        "tag": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "IfNotPresent",
            "Always",
            "Never"
          ]
        }
      },
      "required": [
        "repository",
        "tag"
      ]
    },
    "awsEnvSecrets": {
      "type": "object",
      "properties": {
        "env_secret_name": {
          "type": "string"
        },
        "externalSecret": {
          "type": "object",
          "properties": {
            "secretPath": {
              "type": "string"
            },
            "secretStoreRef": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "SecretStore",
                    "ClusterSecretStore"
                  ]
                },
                "name": {
                  "type": "string"
                }
              }
            }
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "env_secret_name": {
                "type": "string"
              },
              "externalSecret": {
                "type": "object",
                "properties": {
                  "secretPath": {
                    "type": "string"
                  },
                  "secretStoreRef": {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string",
                        "enum": [
                          "SecretStore",
                          "ClusterSecretStore"
                        ]
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  }
                },
                "required": [
                  "secretPath"
                ]
              }
            },
            "required": [
              "env_secret_name",
              "externalSecret"
            ]
          }
        }
      }
    },
    "serviceMonitor": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "interval": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "alternatePort": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "spread_azs": {
      "type": "boolean"
    },
    "spread_spot": {
      "type": "boolean"
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    }
  },
  "title": "Values",
  "type": "object"
}
