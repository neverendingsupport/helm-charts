{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "image": {
      "properties": {
        "tag": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "IfNotPresent",
            "Always",
            "Never"
          ]
        }
      },
      "required": [
        "repository",
        "tag"
      ]
    },
    "awsEnvSecrets": {
      "properties": {
        "externalSecret": {
          "properties": {
            "secretStoreRef": {
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "SecretStore",
                    "ClusterSecretStore"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "serviceMonitor": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "interval": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "alternatePort": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "service": {
      "properties": {
        "type": {
          "type": "string"
        },
        "labels": {
          "type": "object"
        },
        "annotations": {
          "type": "object"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "extraPorts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "port"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "targetPort": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                  },
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "protocol": {
                "type": "string",
                "enum": [
                  "TCP",
                  "UDP",
                  "SCTP"
                ]
              }
            }
          }
        }
      }
    },
    "spread_azs": {
      "type": "boolean"
    },
    "spread_spot": {
      "type": "boolean"
    },
    "terminationGracePeriodSeconds": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 900
        },
        {
          "type": "null"
        }
      ]
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    }
  },
  "title": "Values",
  "type": "object"
}
